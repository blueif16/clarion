# ── Clarion agent — local secrets ──────────────────────────────────────────
# Copy this to  agent/.env  (which is gitignored) and fill in the values.
# NEVER commit the filled-in .env. Don't paste live secrets into chat — edit
# agent/.env directly (e.g. in your editor, or `! nano agent/.env`).

# ---- LiveKit (voice transport plane) ---------------------------------------
# LiveKit Cloud free tier: https://cloud.livekit.io  → project → Settings → Keys
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- Agent brain (LLM for plan / propose) ----------------------------------
# LLM_PROVIDER: openai | anthropic | openai-compatible | google
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=                 # e.g. gpt-4o, claude-sonnet-4-6, or your provider's model id
LLM_BASE_URL=              # ONLY for openai-compatible / self-hosted endpoints; else blank

# ---- Voice pipeline (needed for the FULL S1 barge-in test) -----------------
# Path A (LEANEST): one realtime speech-to-speech model = STT+LLM+TTS in one.
#   Set REALTIME_MODE=1 and provide the key below; STT/TTS keys then unused.
REALTIME_MODE=
OPENAI_API_KEY=            # if using OpenAI Realtime as the brain+voice

# Path B (MODULAR): separate STT + TTS providers.
STT_PROVIDER=              # e.g. deepgram
DEEPGRAM_API_KEY=
STT_MODEL=nova-3           # Deepgram model (nova-3 = latest)
STT_LANGUAGE=en-US         # en-US | zh-CN (Mandarin) | zh-HK (Cantonese) | multi (EN+EU/JA, NO Chinese). One stream can't mix EN+Chinese.
STT_ENDPOINTING_MS=300     # silence (ms) before finalizing a segment; raise if speech gets chopped mid-word, lower for snappier turns
TTS_PROVIDER=              # e.g. cartesia | openai | elevenlabs
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
# (Silero VAD + LiveKit turn detection are local/free — no key needed.)

# ---- MiniMax (the brain + the voice) ---------------------------------------
# LLM  = MiniMax-M3 (OpenAI-compatible: https://api.minimax.io/v1) — both the
#        kernel Reasoner and the LiveKit voice-plane LLM.
# TTS  = MiniMax Speech 2.6-turbo (/v1/t2a_v2) — kernel Synthesizer + LiveKit TTS.
# Wired through the LiveKit `minimax` plugin (reads MINIMAX_API_KEY/MINIMAX_GROUP_ID).
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=                 # required by the LiveKit minimax plugin + t2a_v2 ?GroupId=
# Voice LLM = MiniMax M-series via its ANTHROPIC-compatible gateway (LiveKit `anthropic`
# plugin) — native `thinking` blocks are dropped from spoken text, so no reasoning leak.
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic  # the Anthropic Messages gateway
MINIMAX_LLM_MODEL=MiniMax-M3      # reasoner + voice LLM model id (primary)
MINIMAX_LLM_MODEL_FALLBACK=MiniMax-M2.7  # voice-plane failover when M3 5xx's (llm.FallbackAdapter); blank → MiniMax-M2.7, `off` to disable
MINIMAX_LLM_MAX_TOKENS=2048       # answer budget (shared with M3's thinking; plugin default 1024 can truncate)
MINIMAX_LLM_ATTEMPT_TIMEOUT=12    # secs before a hung primary fails over (generous for M3 reasoning)
MINIMAX_TTS_MODEL=speech-2.6-turbo
MINIMAX_TTS_VOICE=Friendly_Person # any MiniMax voice_id (e.g. Calm_Woman, Patient_Man, Wise_Woman)
# MINIMAX_BASE_URL / MINIMAX_TTS_HOST override the endpoints (default api.minimax.io).

# ---- Retrieval (Moss vector store) -----------------------------------------
# MOSS_EMBED_MODEL picks the embedding path:
#   moss-minilm / moss-mediumlm  → Moss embeds locally in its Rust runtime (no key,
#                                  sub-10ms, no per-query RPC). The DEFAULT path
#                                  (Moss's own docs use model_id="moss-minilm"); the
#                                  model host models.moss.link is back to a clean TLS
#                                  handshake (re-probed 2026-06-06).
#   gemini / unset               → fallback: Gemini custom vectors (gemini-embedding-001,
#                                  needs GOOGLE_API_KEY) — a cloud embed RPC per query,
#                                  for when the model host is unreachable.
# The two are NOT mixable in one index — changing this REQUIRES rebuilding the KB.
MOSS_EMBED_MODEL=moss-minilm
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX=clarion-kb
MOSS_API_KEY=
